// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
  SUPER_ADMIN
}

model Blog {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  coverImage  String?
  category    String   @default("General")
  tags        String   @default("")
  published   Boolean  @default(false)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Property {
  id          String          @id @default(cuid())
  title       String
  slug        String          @unique
  description String
  price       Float
  type        PropertyType    @default(SALE)
  category    String          @default("Residential")
  bedrooms    Int             @default(0)
  bathrooms   Int             @default(0)
  area        Float           @default(0)
  address     String
  city        String
  location    String
  images      String          @default("")
  featured    Boolean         @default(false)
  status      PropertyStatus  @default(AVAILABLE)
  agentId     String?
  agent       Agent?          @relation(fields: [agentId], references: [id])
  views       Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum PropertyType {
  SALE
  RENT
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  RENTED
}

model Agent {
  id         String     @id @default(cuid())
  name       String
  email      String     @unique
  phone      String
  bio        String
  image      String?
  properties Property[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PageView {
  id        String   @id @default(cuid())
  page      String
  userAgent String?
  ip        String?
  country   String?
  createdAt DateTime @default(now())
}

model Visitor {
  id        String   @id @default(cuid())
  date      String   @unique
  count     Int      @default(0)
}
